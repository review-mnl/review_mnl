# Copy this file to .env and fill in your actual values
PORT=5000
CLIENT_URL=http://localhost:5500

# MySQL database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root1234
DB_NAME=reviewmnl_db

# JWT
JWT_SECRET=reviewmnl_jwt_secret_2026_jake
JWT_EXPIRES_IN=24h

# Google OAuth  (console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI to add: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth  (developers.facebook.com → Your App → Facebook Login → Settings)
# Valid OAuth Redirect URI to add: http://localhost:5000/api/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Email (for verification & password reset)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=no-reply@review.mnl
